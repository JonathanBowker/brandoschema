{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/context/post_booking/support_disruption",
      "@type": "brando:Context",
      "schema:name": "Icelandair Post-Booking Support & Disruption Context",
      "schema:description": "Applies to all customer communications after booking where support, disruption, delays, cancellations, or service failures occur.",

      "brando:audienceSegment": [
        "Confirmed passengers",
        "Affected customers"
      ],

      "brando:journeyStage": "post-booking",

      "brando:emotionalStateAssumption": [
        "uncertainty",
        "stress",
        "time sensitivity"
      ],

      "brando:communicationGoals": [
        "Reduce anxiety",
        "Explain the situation clearly",
        "Provide next steps",
        "Restore trust"
      ],

      "brando:toneOverrides": {
        "empathy": 5,
        "clarity": 5,
        "warmth": 4,
        "authority": 4,
        "playfulness": 0,
        "urgency": 3
      },

      "brando:usesVerbalIdentity": {
        "@id": "https://brandoschema.com/icelandair/verbal-identity/support_disruption"
      },

      "brando:hasPolicy": [
        {
          "@id": "https://brandoschema.com/icelandair/policies/support_disruption"
        },
        {
          "@id": "https://brandoschema.com/icelandair/policies/empathy_accountability"
        }
      ],

      "brando:guardRails": [
        "No humor",
        "No marketing language",
        "Acknowledge inconvenience explicitly",
        "Never assign blame to the customer"
      ],

      "brando:requiredBehaviors": [
        "State what happened",
        "State what customers can do next",
        "State what Icelandair is doing to help"
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
