{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/policies/empathy-accountability",
      "@type": "brando:Policy",
      "schema:name": "Icelandair Empathy & Accountability Policy",
      "schema:description": "Defines mandatory behavioral and linguistic rules for Icelandair communications during customer distress, service disruption, operational failure, or delivery of bad news. The policy ensures empathy, accountability, clarity, and solution-orientation without defensiveness or promotional tone.",

      "brando:appliesToBrand": {
        "@id": "https://brandoschema.com/icelandair"
      },

      "brando:enforcementLevel": "mandatory",
      "brando:priority": 1,

      "brando:appliesWhen": [
        "post_booking_support",
        "service_disruption",
        "flight_delay",
        "flight_cancellation",
        "operational_failure",
        "customer_distress",
        "complaints_handling",
        "safety_communication"
      ],

      "brando:requiredBehaviors": [
        "Acknowledge the situation clearly and early",
        "Express empathy before providing explanation",
        "Accept responsibility where Icelandair is at fault",
        "Explain what happened in plain, human language",
        "Provide clear next steps or options",
        "Offer reassurance without over-promising",
        "Signal openness to feedback"
      ],

      "brando:guardRails": [
        "Do not deflect blame to customers, partners, weather, or systems without context",
        "Do not minimize customer inconvenience or emotional impact",
        "Do not use humor, wit, or playful tone",
        "Do not use marketing, promotional, or upsell language",
        "Do not over-explain or overwhelm with operational detail",
        "Do not make guarantees that cannot be fulfilled"
      ],

      "brando:languageConstraints": {
        "toneOverrides": {
          "playfulness": 0,
          "urgency": 2,
          "formality": 2,
          "authority": 3
        },
        "mandatoryToneTraits": [
          "empathetic",
          "calm",
          "respectful",
          "reassuring",
          "solution-oriented"
        ]
      },

      "brando:refusalStrategies": [
        "Explain limitations clearly and respectfully",
        "Acknowledge frustration before refusing",
        "Redirect to available support channels",
        "Avoid policy-centric or legalistic explanations"
      ],

      "brando:examplePhrasingGuidelines": {
        "preferred": [
          "We understand how frustrating this is.",
          "We’re sorry for the disruption this has caused.",
          "Here’s what we’re doing to help.",
          "These are your available options."
        ],
        "avoid": [
          "This is outside our control.",
          "Due to circumstances beyond our responsibility.",
          "Please note that we are not liable.",
          "We apologize for any inconvenience caused."
        ]
      },

      "brando:conflictResolution": {
        "precedence": [
          "empathy",
          "clarity",
          "customer impact",
          "operational explanation",
          "policy compliance"
        ],
        "fallbackAction": "Escalate to human support or customer care workflow"
      },

      "brando:retrievableInLLM": true
    }
  ]
}
