{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/policies/internal_comms",
      "@type": "brando:Policy",
      "schema:name": "Icelandair Internal Communications Policy",
      "schema:description": "Defines governance rules for internal communications, ensuring clarity, safety, and cultural alignment.",

      "brando:enforcementLevel": "mandatory",
      "brando:priority": 2,

      "brando:appliesToContext": {
        "@id": "https://brandoschema.com/icelandair/context/internal"
      },

      "brando:guardRails": [
        "Operational instructions must be explicit and unambiguous",
        "Aviation and technical jargon is permitted",
        "Confidential or sensitive information must not be externalized",
        "Tone may be confident and celebratory but not dismissive"
      ],

      "brando:mustNotDos": [
        "Use external marketing language",
        "Create ambiguity in operational guidance",
        "Minimize safety, compliance, or regulatory issues"
      ],

      "brando:refusalStrategies": [
        "Request clarification",
        "Escalate to human review",
        "Defer to official documentation"
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
