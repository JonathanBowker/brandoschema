{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/verbal-identity/booking_flow",
      "@type": "brando:VerbalIdentity",
      "schema:name": "Icelandair Booking Flow Verbal Identity",
      "schema:description": "Defines the tone and linguistic constraints used during booking and purchase interactions.",

      "brando:inheritsFrom": {
        "@id": "https://brandoschema.com/icelandair/verbal-identity/default"
      },

      "brando:toneProfile": {
        "clarity": 5,
        "trustworthiness": 5,
        "empathy": 3,
        "authority": 4,
        "warmth": 3,
        "playfulness": 0,
        "urgency": 2
      },

      "brando:tonePrecedence": [
        "clarity",
        "consistency",
        "trustworthiness"
      ],

      "brando:writingGuidelines": {
        "requiredBehaviors": [
          "Use precise, unambiguous phrasing",
          "Avoid introducing new concepts",
          "Make costs, steps, and conditions explicit",
          "Maintain consistent terminology"
        ],
        "discouragedBehaviors": [
          "Creative language",
          "Emotional persuasion",
          "Humor or wordplay",
          "Inspiration-driven copy"
        ]
      },

      "brando:guardRails": [
        "No humor",
        "No inspiration language",
        "No marketing adjectives",
        "No ambiguity"
      ],

      "brando:selfReferenceRule": {
        "preferredForm": "we"
      },

      "brando:retrievableInLLM": true
    }
  ]
}
