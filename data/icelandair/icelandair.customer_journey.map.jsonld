{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/customer-journey",
      "@type": "brando:JourneyMap",
      "schema:name": "Icelandair Customer Journey Map",
      "schema:description": "Defines the primary customer journey stages and their associated communication contexts.",

      "brando:journeyStages": [
        {
          "stage": "pre_booking",
          "description": "Inspiration, awareness, and engagement",
          "usesContext": {
            "@id": "https://brandoschema.com/icelandair/context/pre_booking"
          }
        },
        {
          "stage": "booking",
          "description": "Flight selection, payment, and confirmation",
          "usesContext": {
            "@id": "https://brandoschema.com/icelandair/context/booking_flow"
          }
        },
        {
          "stage": "post_booking",
          "description": "Pre-flight information, support, and updates",
          "usesContext": {
            "@id": "https://brandoschema.com/icelandair/context/post_booking_support"
          }
        },
        {
          "stage": "disruption",
          "description": "Delays, cancellations, or service issues",
          "usesContext": {
            "@id": "https://brandoschema.com/icelandair/context/support_disruption"
          }
        },
        {
          "stage": "internal",
          "description": "Employee and operational communications",
          "usesContext": {
            "@id": "https://brandoschema.com/icelandair/context/internal"
          }
        }
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
