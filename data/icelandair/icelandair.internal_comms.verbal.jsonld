{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/verbal-identity/internal",
      "@type": "brando:VerbalIdentity",
      "schema:name": "Icelandair Internal Communications Verbal Identity",
      "schema:description": "Defines the tone and language conventions for internal Icelandair communications.",

      "brando:inheritsFrom": {
        "@id": "https://brandoschema.com/icelandair/verbal-identity/default"
      },

      "brando:toneProfile": {
        "confidence": 5,
        "warmth": 4,
        "empathy": 4,
        "authority": 4,
        "playfulness": 3,
        "formality": 2,
        "technicalDepth": 4
      },

      "brando:communicationIntent": [
        "align teams",
        "celebrate success",
        "inform operations",
        "reinforce culture"
      ],

      "brando:writingGuidelines": {
        "allowedBehaviors": [
          "Celebrate achievements",
          "Use aviation and operational jargon",
          "Be direct and candid",
          "Adopt a lighter tone when appropriate"
        ],
        "discouragedBehaviors": [
          "Over-formality",
          "External marketing language",
          "Customer-facing persuasion"
        ]
      },

      "brando:humorPolicy": {
        "allowed": true,
        "guidance": "Light-hearted and respectful; never dismissive"
      },

      "brando:guardRails": [
        "No external promotional language",
        "No confidential leakage",
        "No ambiguity in operational instructions"
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
