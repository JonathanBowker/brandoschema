{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/policies/localization",
      "@type": "brando:Policy",
      "schema:name": "Icelandair Localization & Translation Policy",
      "schema:description": "Defines rules for translating and localizing Icelandair communications across languages and markets.",

      "brando:enforcementLevel": "mandatory",
      "brando:priority": 2,

      "brando:requiredBehaviors": [
        "Preserve meaning over literal translation",
        "Maintain conversational tone within cultural norms",
        "Adjust phrasing for clarity where needed",
        "Respect formality conventions of each language"
      ],

      "brando:languageSpecificRules": {
        "French": {
          "formality": "formal"
        },
        "German": {
          "formality": "formal"
        },
        "English": {
          "formality": "informal"
        }
      },

      "brando:guardRails": [
        "Avoid idioms that do not translate",
        "Avoid humor that is culturally dependent",
        "Avoid direct word-for-word translation"
      ],

      "brando:mustNotDos": [
        "Sound robotic or overly literal",
        "Introduce cultural bias",
        "Lose clarity for stylistic reasons"
      ],

      "brando:reviewWorkflow": "Localization reviewed by Icelandair marketing team when ambiguity exists",

      "brando:retrievableInLLM": true
    }
  ]
}
