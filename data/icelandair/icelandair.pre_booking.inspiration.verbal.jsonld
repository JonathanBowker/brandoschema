{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/verbal-identity/pre_booking_inspiration",
      "@type": "brando:VerbalIdentity",
      "schema:name": "Icelandair Pre-Booking Inspiration Verbal Identity",
      "schema:description": "Defines the tone and language used to inspire, engage, and emotionally connect with audiences before booking.",

      "brando:inheritsFrom": {
        "@id": "https://brandoschema.com/icelandair/verbal-identity/default"
      },

      "brando:toneProfile": {
        "warmth": 4,
        "empathy": 4,
        "trustworthiness": 4,
        "authority": 3,
        "playfulness": 3,
        "creativity": 4,
        "urgency": 1
      },

      "brando:tonePrecedence": [
        "warmth",
        "curiosity",
        "trustworthiness",
        "playfulness"
      ],

      "brando:writingGuidelines": {
        "requiredBehaviors": [
          "Spark curiosity about Iceland and travel",
          "Use engaging and memorable language",
          "Invite exploration and imagination",
          "Be welcoming and inclusive"
        ],
        "discouragedBehaviors": [
          "Hard selling",
          "Pressure tactics",
          "Over-technical explanations",
          "Operational detail"
        ]
      },

      "brando:humorProfile": {
        "baselineLevel": 3,
        "allowedForms": [
          "light wit",
          "gentle surprise",
          "wordplay"
        ],
        "restrictedForms": [
          "sarcasm",
          "dark humor",
          "humor based on exclusion"
        ]
      },

      "brando:selfReferenceRule": {
        "preferredForm": "we"
      },

      "brando:retrievableInLLM": true
    }
  ]
}
