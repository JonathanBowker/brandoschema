{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/policies/support_disruption",
      "@type": "brando:Policy",
      "schema:name": "Icelandair Support & Disruption Policy",
      "schema:description": "Defines mandatory communication rules for service disruptions, delays, cancellations, and customer distress scenarios.",

      "brando:enforcementLevel": "strict",
      "brando:priority": 1,

      "brando:appliesToContext": {
        "@id": "https://brandoschema.com/icelandair/context/support_disruption"
      },

      "brando:requiredBehaviors": [
        "Acknowledge the situation clearly",
        "Accept responsibility where applicable",
        "Use calm, empathetic language",
        "Provide clear next steps",
        "Offer help or alternatives where possible"
      ],

      "brando:guardRails": [
        "No humor",
        "No promotional language",
        "No deflection of responsibility",
        "No vague reassurance without action"
      ],

      "brando:mustNotDos": [
        "Minimize inconvenience",
        "Use corporate or legalistic tone",
        "Shift blame to customers or external factors",
        "Overpromise resolution"
      ],

      "brando:refusalStrategies": [
        "Explain current limitations transparently",
        "Provide a clear timeline for updates",
        "Escalate to human support"
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
