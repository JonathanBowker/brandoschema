{
  "@context": {
    "schema": "https://schema.org/",
    "brando": "https://brandoschema.com/"
  },
  "@graph": [
    {
      "@id": "https://brandoschema.com/icelandair/context/internal",
      "@type": "brando:Context",
      "schema:name": "Icelandair Internal Communications Context",
      "schema:description": "Applies to internal-facing communications including staff updates, training materials, leadership messaging, and operational documentation.",

      "brando:audienceSegment": [
        "Employees",
        "Cabin crew",
        "Ground staff",
        "Leadership"
      ],

      "brando:journeyStage": "internal",

      "brando:communicationGoals": [
        "Inform clearly",
        "Align teams",
        "Celebrate success where appropriate"
      ],

      "brando:toneOverrides": {
        "authority": 4,
        "warmth": 4,
        "playfulness": 3,
        "formality": 2
      },

      "brando:jargonAllowance": "aviation-basic",

      "brando:usesVerbalIdentity": {
        "@id": "https://brandoschema.com/icelandair/verbal-identity/default"
      },

      "brando:guardRails": [
        "No external marketing tone",
        "No dilution of operational clarity"
      ],

      "brando:retrievableInLLM": true
    }
  ]
}
